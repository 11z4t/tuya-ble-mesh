{
  "entity": {
    "light": {
      "mesh_light": {
        "default": "mdi:lightbulb-group"
      }
    },
    "switch": {
      "mesh_switch": {
        "default": "mdi:power-socket"
      }
    },
    "sensor": {
      "rssi": {
        "default": "mdi:signal"
      },
      "firmware": {
        "default": "mdi:chip"
      },
      "power": {
        "default": "mdi:flash"
      },
      "energy": {
        "default": "mdi:lightning-bolt"
      }
    },
    "update": {
      "firmware_update": {
        "default": "mdi:package-up"
      }
    },
    "event": {
      "device_connected": {
        "default": "mdi:connection"
      },
      "device_disconnected": {
        "default": "mdi:connection-off"
      },
      "provisioning_complete": {
        "default": "mdi:check-circle"
      },
      "mesh_authenticated": {
        "default": "mdi:shield-check"
      }
    }
  },
  "services": {
    "identify": "mdi:magnify",
    "set_log_level": "mdi:text-box-outline",
    "get_diagnostics": "mdi:information-outline"
  }
