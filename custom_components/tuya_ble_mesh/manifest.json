{
  "domain": "tuya_ble_mesh",
  "name": "Tuya BLE Mesh",
  "version": "0.25.21",
  "integration_type": "hub",
  "documentation": "https://github.com/11z4t/tuya-ble-mesh",
  "issue_tracker": "https://github.com/11z4t/tuya-ble-mesh/issues",
  "codeowners": [
    "@kvista-se"
  ],
  "config_flow": true,
  "iot_class": "local_push",
  "loggers": ["tuya_ble_mesh"],
