    {
      "local_name": "out_of_mesh*"
    },
    {
      "local_name": "tymesh*"
    }
  ],
  "dependencies": [
    "bluetooth"
  ],
  "requirements": ["bleak>=0.21", "bleak-retry-connector>=3.0", "cryptography>=42.0"]
}
