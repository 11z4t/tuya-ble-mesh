{
  "domain": "tuya_ble_mesh",
  "name": "Tuya BLE Mesh",
  "version": "0.30.4",
  "integration_type": "device",
  "documentation": "https://github.com/11z4t/tuya-ble-mesh",
  "issue_tracker": "https://github.com/11z4t/tuya-ble-mesh/issues",
  "codeowners": [
    "@11z4t"
  ],
  "config_flow": true,
  "iot_class": "local_push",
  "quality_scale": "platinum",
  "loggers": [
    "tuya_ble_mesh"
  ],
  "bluetooth": [
    {
      "local_name": "out_of_mesh*"
    }
  ],
  "dependencies": [
    "bluetooth"
  ],
  "requirements": [
    "bleak>=0.21",
    "bleak-retry-connector>=3.0",
    "cryptography>=42.0"
  ]
}